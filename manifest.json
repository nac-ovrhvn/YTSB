{
  "manifest_version": 2,
  "name": "YTSB",
  "version": "1.0.0",
  "description": "A minimalist YouTube experience: redirect home to subscriptions, hide Shorts, and clean up the sidebar.",
  "author": "YTSB Contributors",
  "homepage_url": "https://github.com/nac-ovrhvn/YTSB",
  "icons": {
    "48": "icons/icon48.png",
    "96": "icons/icon96.png"
  },
  "browser_action": {
    "default_icon": {
      "48": "icons/icon48.png"
    },
    "default_popup": "popup/popup.html",
    "default_title": "YTSB"
  },
  "permissions": [
    "storage",
    "tabs"
  ],
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    "icons/*.png"
  ]
}
